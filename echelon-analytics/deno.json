{
  "nodeModulesDir": "manual",
  "tasks": {
    "check": "deno fmt --check . && deno lint . && deno check main.ts && deno task test",
    "test": "deno test -A --no-check --ignore=tests/e2e tests/",
    "test:e2e": "deno test -A --no-check tests/e2e/",
    "dev": "vite",
    "build": "vite build",
    "start": "deno serve -A --port=${ECHELON_PORT:-1947} _fresh/server.js",
    "update": "deno run -A -r jsr:@fresh/update .",
    "mcp": "deno run -A mcp-server.ts"
  },
  "lint": {
    "rules": {
      "tags": ["fresh", "recommended"],
      "exclude": ["react-no-danger"]
    }
  },
  "exclude": ["**/_fresh/*", "echelon.db*"],
  "imports": {
    "@/": "./",
    "fresh": "jsr:@fresh/core@^2.2.2",
    "preact": "npm:preact@^10.28.3",
    "@preact/signals": "npm:@preact/signals@^2.7.1",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.0.8",
    "vite": "npm:vite@^7.1.3",
    "tailwindcss": "npm:tailwindcss@^4.1.10",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.1.12",
    "@std/assert": "jsr:@std/assert@^1",
    "@std/testing/time": "jsr:@std/testing@^1/time",
    "@astral/astral": "jsr:@astral/astral@^0.5",
    "@types/node": "npm:@types/node@^22.19.11",
    "@modelcontextprotocol/sdk": "npm:@modelcontextprotocol/sdk@^1.12.1",
    "zod": "npm:zod@^3.24.4"
  },
  "compilerOptions": {
    "lib": ["dom", "dom.asynciterable", "dom.iterable", "deno.ns"],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": ["vite/client"]
  }
}
